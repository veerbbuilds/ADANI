rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 👤 Users Collection: Users can view and manage only their own authentication profile
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // 🪵 Yard Movement Logs: Read-only for authenticated users, writes ONLY via Admin SDK (API routes)
    // 🔒 HARDENED: Deny direct client writes — prevents bypassing API-level validation, rate limits, and audit logging (CWE-732)
    match /yard_logs/{logId} {
      allow read: if request.auth != null;
      allow write: if false; // Server-side Admin SDK only
    }
    
    // ⚙️ Settings Collection: Permissions, system config, notifications
    // Readable by authenticated users, writable only by Admin/Developer (via Admin SDK in practice)
    match /settings/{document} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.token.role == 'admin' || 
        request.auth.token.role == 'superadmin'
      );
    }

    // 📑 Secure Audit Trail: Server-side only — no direct client access
    // 🔒 HARDENED: Deny ALL direct client reads/writes — only Admin SDK (CWE-732)
    match /audit_logs/{logId} {
      allow read, write: if false; // Server-side Admin SDK only
    }

    // 🔒 Default Deny: Block all other unauthorized direct database paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
